<?xml version="1.0" encoding="utf-8" ?>
<MasterDetailPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="meds.MainPage">
    <MasterDetailPage.Master>
        <ContentPage
            BackgroundColor="#547569"
            Title="☰"
            
            Padding="0,60,0,0">
            <ListView HasUnevenRows="False" x:Name="ListMenu" BackgroundColor="#86b0a0" RowHeight="100" SeparatorColor="Gray" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextCell  TextColor="White" 
                                   DetailColor="LightGray" 
                                   Text="{Binding MenuTitle}"
                                   Detail="{Binding MenuDetail}"
                                   >
                        </TextCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ContentPage>
    </MasterDetailPage.Master>
    <MasterDetailPage.Detail>
        <NavigationPage BackgroundColor="#9bc4b5">
            <x:Arguments>
                <ContentPage BackgroundColor="#b2d4c7"></ContentPage>
            </x:Arguments>
        </NavigationPage>
    </MasterDetailPage.Detail>
</MasterDetailPage>
